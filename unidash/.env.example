# UniDash Environment Variables

# JWT Security Secrets (GENERATE NEW VALUES FOR PRODUCTION!)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-me
JWT_REFRESH_SECRET_KEY=your-refresh-secret-key-here-change-me

# Database (optional, defaults to SQLite)
# DATABASE_URL=sqlite:///./data/unidash.db
# DATABASE_URL=postgresql://user:password@localhost/unidash

# Rate Limiting (optional)
# RATE_LIMIT_PER_MINUTE=60
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_DURATION_MINUTES=15

# CORS Origins (optional)
# CORS_ORIGINS=["http://localhost:9999","http://your-domain.com"]
